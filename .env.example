# Firebase Client Credentials
# Create a web app in your Firebase Console (Console > Project Settings > General) to retrieve these keys.
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyYourApiKeyHere"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-app-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-app-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="1:your-app-id:web:your-web-app-id"
